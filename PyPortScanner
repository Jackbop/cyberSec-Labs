import socket # La libreria per le connessioni di rete
import sys    # Per gestire gli argomenti da terminale

def port_scanner(target_ip):
    # Definiamo una lista di porte comuni da testare
    common_ports = [21, 22, 23, 25, 53, 80, 110, 443, 445, 3306, 3389]
    
    print(f"\n--- Scansione avviata su: {target_ip} ---")
    
    try:
        for port in common_ports:
            # Creiamo il "socket" (AF_INET = IPv4, SOCK_STREAM = TCP)
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            
            # Impostiamo un timeout di 1 secondo (se non risponde, passa oltre)
            s.settimeout(1)
            
            # Tenta la connessione. 
            # connect_ex restituisce 0 se la porta è APERTA
            result = s.connect_ex((target_ip, port))
            
            if result == 0:
                print(f"[+] Porta {port}: APERTA")
            
            s.close() # Chiudiamo sempre la connessione
            
    except KeyboardInterrupt:
        print("\n Scansione interrotta dall'utente.")
        sys.exit()
    except Exception as e:
        print(f"\n Errore: {e}")
        sys.exit()

# Punto di ingresso del programma
if __name__ == "__main__":
    if len(sys.argv) == 2:
        target = sys.argv[1] # Prende l'IP dal comando: python3 scanner.py IP
        port_scanner(target)
    else:
        print("Utilizzo: python3 scanner.py <IP_TARGET>")
